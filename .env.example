# PriceAlert local example environment

# App
PRICEALERT_APP_NAME=pricealert
PRICEALERT_RUNTIME_TIMEZONE=UTC
PRICEALERT_LOG_LEVEL=info

# Runtime
PRICEALERT_MIN_SCAN_INTERVAL_MINS=5
PRICEALERT_MAX_CONCURRENT_SCANS=1

# Database
PRICEALERT_DB_DRIVER=mysql
PRICEALERT_DB_HOST=127.0.0.1
PRICEALERT_DB_PORT=3306
PRICEALERT_DB_USER=root
PRICEALERT_DB_PASSWORD=password
PRICEALERT_DB_NAME=pricealert
PRICEALERT_DB_PARAMS=parseTime=true&charset=utf8mb4&loc=UTC

# Paths
PRICEALERT_MIGRATIONS_DIR=migrations

# Scraper
PRICEALERT_TOKOPEDIA_SEARCH_ENDPOINT=https://gql.tokopedia.com/graphql/SearchProductV5Query
PRICEALERT_SCRAPER_TIMEOUT_SECONDS=20
PRICEALERT_SCRAPER_ROWS_PER_SCAN=10

# Telegram
# Leave both empty to disable Telegram delivery.
PRICEALERT_TELEGRAM_BOT_TOKEN=
PRICEALERT_TELEGRAM_CHAT_ID=
PRICEALERT_TELEGRAM_API_BASE_URL=https://api.telegram.org
PRICEALERT_TELEGRAM_TIMEOUT_SECONDS=10

# Startup maintenance
# Set to 0 to disable a retention policy.
PRICEALERT_RAW_LISTING_RETENTION_HOURS=336
PRICEALERT_ALERT_EVENT_RETENTION_HOURS=720
